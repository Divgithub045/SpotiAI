{
  "manifest_version": 3,
  "name": "Spotify AI Playlist Creator",
  "version": "1.0.0",
  "description": "Generate personalized Spotify playlists using Google Gemini AI combined with your listening taste profile.",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://spotiai.onrender.com/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["callback.html"],
      "matches": ["https://spotiai.onrender.com/*"]
    }
  ]
}
